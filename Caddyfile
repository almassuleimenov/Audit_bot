# Caddyfile
# Локальная конфигурация для тестирования. 
# В продакшене вместо :80 будет указан твой домен (например, yourdomain.kz), 
# и Caddy автоматически выпишет SSL сертификат.

:80 {
    # Включаем сжатие ответов для экономии трафика (O(N) процессорного времени, где N - размер ответа, но сильно ускоряет сеть)
    encode gzip zstd

    # Все запросы к API направляем в контейнер бэкенда
    handle /api/* {
        reverse_proxy backend:8080
    }

    # Все остальные запросы (UI дашборда) направляем в Next.js
    handle /* {
        reverse_proxy frontend:3000
    }

    # Логирование для SRE-мониторинга
    log {
        output stdout
        format console
    }
}